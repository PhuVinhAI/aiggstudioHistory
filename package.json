{
  "name": "ai-studio-archiver-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @ai-studio-archiver/extension",
    "build": "npm run build -w @ai-studio-archiver/extension",
    "build:cli": "cd packages/cli && cargo build --release",
    "lint": "npm run lint -w @ai-studio-archiver/extension"
  },
  "devDependencies": {
    "@types/node": "^24.12.0"
  }
}
